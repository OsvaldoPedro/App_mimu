# Mimu App - Exemplo de Configuração de Variáveis de Ambiente
# Copie este ficheiro para .env ou .env.local e preencha com os seus dados do Supabase.

# URL do seu projeto Supabase (disponível em Settings > API)
VITE_SUPABASE_URL=https://seu-projeto-id.supabase.co

# Chave anónima pública do seu projeto Supabase (disponível em Settings > API)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-key-aqui
